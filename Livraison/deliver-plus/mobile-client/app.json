{
  "expo": {
    "name": "Amnir Client",
    "slug": "amnir-client",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3B328F"
      },
      "package": "mr.amnir.client",
      "config": {
        "googleMaps": {
          "apiKey": "REMPLACE_PAR_TA_CLE_GOOGLE_MAPS"
        }
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "ios": {
      "bundleIdentifier": "mr.amnir.client",
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Amnir a besoin de votre position pour la livraison.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Amnir a besoin de votre position pour la livraison."
      }
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Amnir a besoin de votre position pour la livraison."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon.png",
          "color": "#3B328F",
          "defaultChannel": "default"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "1c013254-1246-486a-bbab-915f7bc441c7"
      }
    },
    "owner": "lebatt"
  }
}
